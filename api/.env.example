# Copia este fichero a api/.env y rellena los valores. NUNCA subas .env a git.

# Render > tu base de datos > "Internal Database URL" (si la API esta en Render)
# o "External Database URL" (si pruebas desde tu portatil).
DATABASE_URL=postgresql://usuario:password@host/basededatos

# Secreto para firmar los tokens de sesion. Genera uno con:
#   openssl rand -hex 32
# Si esto se filtra, cualquiera puede firmar tokens y entrar como cualquier cliente.
JWT_SECRET=

# Dominios que pueden llamar a la API desde el navegador, separados por comas.
CORS_ORIGINS=https://goldcorp.online,https://www.goldcorp.online

# Solo para Postgres local sin TLS. En Render dejalo sin tocar.
# PGSSL=off
